#!/usr/bin/env bash
# =============================================================================
# Hook de pre-commit - Pipeline MLOps
# Verifie la qualite du code, detecte des secrets et bloque les gros fichiers
# hors Git LFS avant le commit.
# =============================================================================

set -u

echo "======================================"
echo "  PRE-COMMIT HOOK - Verification"
echo "======================================"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

ERRORS=0
MAX_SIZE=$((5 * 1024 * 1024))
STAGED_FILES=()
PYTHON_FILES=()

while IFS= read -r file; do
    if [ -n "$file" ]; then
        STAGED_FILES+=("$file")
        if [[ "$file" == *.py ]]; then
            PYTHON_FILES+=("$file")
        fi
    fi
done < <(git diff --cached --name-only --diff-filter=ACM)

if [ ${#STAGED_FILES[@]} -eq 0 ]; then
    echo -e "${GREEN}Aucun fichier stage, rien a verifier.${NC}"
    exit 0
fi

echo -e "\n${YELLOW}[1/4] Verification syntaxe (flake8 + py_compile)...${NC}"
if [ ${#PYTHON_FILES[@]} -eq 0 ]; then
    echo -e "${YELLOW}WARN : aucun fichier Python stage.${NC}"
else
    if command -v flake8 >/dev/null 2>&1; then
        flake8 "${PYTHON_FILES[@]}" --max-line-length=120 --statistics
        if [ $? -ne 0 ]; then
            echo -e "${RED}ECHEC : erreurs flake8 detectees.${NC}"
            ERRORS=$((ERRORS + 1))
        else
            echo -e "${GREEN}OK : flake8 passe.${NC}"
        fi
    else
        echo -e "${YELLOW}WARN : flake8 non installe, verification ignoree.${NC}"
    fi

    if command -v python >/dev/null 2>&1; then
        python -m py_compile "${PYTHON_FILES[@]}"
        if [ $? -ne 0 ]; then
            echo -e "${RED}ECHEC : py_compile a detecte une erreur.${NC}"
            ERRORS=$((ERRORS + 1))
        else
            echo -e "${GREEN}OK : py_compile passe.${NC}"
        fi
    else
        echo -e "${YELLOW}WARN : python non disponible.${NC}"
    fi
fi

echo -e "\n${YELLOW}[2/4] Verification formatage (black)...${NC}"
if [ ${#PYTHON_FILES[@]} -eq 0 ]; then
    echo -e "${YELLOW}WARN : aucun fichier Python a formater.${NC}"
elif command -v black >/dev/null 2>&1; then
    black --check "${PYTHON_FILES[@]}"
    if [ $? -ne 0 ]; then
        echo -e "${RED}ECHEC : formatage black invalide.${NC}"
        ERRORS=$((ERRORS + 1))
    else
        echo -e "${GREEN}OK : formatage black valide.${NC}"
    fi
else
    echo -e "${YELLOW}WARN : black non installe, verification ignoree.${NC}"
fi

echo -e "\n${YELLOW}[3/4] Detection de secrets...${NC}"
if command -v detect-secrets-hook >/dev/null 2>&1; then
    detect-secrets-hook "${STAGED_FILES[@]}"
    if [ $? -ne 0 ]; then
        echo -e "${RED}ECHEC : secret potentiel detecte.${NC}"
        ERRORS=$((ERRORS + 1))
    else
        echo -e "${GREEN}OK : aucun secret detecte.${NC}"
    fi
elif command -v detect-secrets >/dev/null 2>&1; then
    SECRET_FOUND=0
    for file in "${STAGED_FILES[@]}"; do
        if [ -f "$file" ] && detect-secrets scan "$file" 2>/dev/null | grep -q '"hashed_secret"'; then
            echo -e "${RED}ALERTE : secret potentiel detecte dans $file${NC}"
            SECRET_FOUND=1
        fi
    done

    if [ $SECRET_FOUND -ne 0 ]; then
        ERRORS=$((ERRORS + 1))
    else
        echo -e "${GREEN}OK : aucun secret detecte.${NC}"
    fi
else
    echo -e "${YELLOW}WARN : detect-secrets non installe, verification ignoree.${NC}"
fi

echo -e "\n${YELLOW}[4/4] Verification taille des fichiers (> 5Mo)...${NC}"
for file in "${STAGED_FILES[@]}"; do
    if [ -f "$file" ]; then
        FILE_SIZE=$(wc -c < "$file" 2>/dev/null || echo 0)
        if [ "$FILE_SIZE" -gt "$MAX_SIZE" ]; then
            if ! git check-attr filter "$file" | grep -q "lfs"; then
                echo -e "${RED}ECHEC : $file fait ${FILE_SIZE} octets et n'est pas dans Git LFS.${NC}"
                echo -e "${RED}Ajoutez-le avec : git lfs track \"$file\"${NC}"
                ERRORS=$((ERRORS + 1))
            fi
        fi
    fi
done

echo ""
if [ $ERRORS -gt 0 ]; then
    echo -e "${RED}======================================"
    echo -e "  COMMIT BLOQUE : $ERRORS erreur(s)"
    echo -e "======================================${NC}"
    exit 1
fi

echo -e "${GREEN}======================================"
echo -e "  TOUTES LES VERIFICATIONS PASSENT"
echo -e "======================================${NC}"
exit 0
