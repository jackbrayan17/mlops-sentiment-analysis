#!/bin/bash
# =============================================================================
# Hook de pre-commit - Pipeline MLOps
# Ce hook verifie :
#   1. La syntaxe du code avec flake8
#   2. Le formatage du code avec black
#   3. La detection de secrets (detect-secrets)
#   4. Que les fichiers > 5Mo sont bien dans Git LFS
# =============================================================================

echo "======================================"
echo "  PRE-COMMIT HOOK - Verification..."
echo "======================================"

# Couleurs pour le terminal
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

ERRORS=0

# -----------------------------------------------
# 1. Verification syntaxe avec flake8
# -----------------------------------------------
echo -e "\n${YELLOW}[1/4] Verification syntaxe (flake8)...${NC}"
if command -v flake8 &> /dev/null; then
    flake8 src/ tests/ app.py --max-line-length=120 --statistics 2>&1
    if [ $? -ne 0 ]; then
        echo -e "${RED}ECHEC : Erreurs flake8 detectees.${NC}"
        ERRORS=$((ERRORS + 1))
    else
        echo -e "${GREEN}OK : Syntaxe valide.${NC}"
    fi
else
    echo -e "${YELLOW}WARN : flake8 non installe, verification ignoree.${NC}"
fi

# -----------------------------------------------
# 2. Verification formatage avec black
# -----------------------------------------------
echo -e "\n${YELLOW}[2/4] Verification formatage (black)...${NC}"
if command -v black &> /dev/null; then
    black --check src/ tests/ app.py 2>&1
    if [ $? -ne 0 ]; then
        echo -e "${RED}ECHEC : Code mal formate. Lancez 'black src/ tests/ app.py'${NC}"
        ERRORS=$((ERRORS + 1))
    else
        echo -e "${GREEN}OK : Formatage correct.${NC}"
    fi
else
    echo -e "${YELLOW}WARN : black non installe, verification ignoree.${NC}"
fi

# -----------------------------------------------
# 3. Detection de secrets
# -----------------------------------------------
echo -e "\n${YELLOW}[3/4] Detection de secrets...${NC}"
if command -v detect-secrets &> /dev/null; then
    # Verifier les fichiers stages pour des secrets
    git diff --cached --name-only | while read file; do
        if [ -f "$file" ]; then
            detect-secrets scan "$file" --list 2>/dev/null | while read line; do
                if [ ! -z "$line" ]; then
                    echo -e "${RED}ALERTE : Secret potentiel detecte dans $file${NC}"
                    ERRORS=$((ERRORS + 1))
                fi
            done
        fi
    done
    echo -e "${GREEN}OK : Aucun secret detecte.${NC}"
else
    echo -e "${YELLOW}WARN : detect-secrets non installe, verification ignoree.${NC}"
fi

# -----------------------------------------------
# 4. Verification taille des fichiers (> 5Mo sans LFS)
# -----------------------------------------------
echo -e "\n${YELLOW}[4/4] Verification taille des fichiers (> 5Mo)...${NC}"
MAX_SIZE=$((5 * 1024 * 1024))  # 5 Mo en octets

git diff --cached --name-only | while read file; do
    if [ -f "$file" ]; then
        FILE_SIZE=$(wc -c < "$file" 2>/dev/null || echo 0)
        if [ "$FILE_SIZE" -gt "$MAX_SIZE" ]; then
            # Verifier si le fichier est dans LFS
            git check-attr filter "$file" | grep -q "lfs"
            if [ $? -ne 0 ]; then
                echo -e "${RED}ECHEC : $file fait ${FILE_SIZE} octets (> 5Mo) et n'est PAS dans Git LFS !${NC}"
                echo -e "${RED}Ajoutez-le avec : git lfs track \"$file\"${NC}"
                ERRORS=$((ERRORS + 1))
            fi
        fi
    fi
done

# -----------------------------------------------
# Resultat final
# -----------------------------------------------
echo ""
if [ $ERRORS -gt 0 ]; then
    echo -e "${RED}======================================"
    echo -e "  COMMIT BLOQUE : $ERRORS erreur(s)"
    echo -e "======================================${NC}"
    exit 1
else
    echo -e "${GREEN}======================================"
    echo -e "  TOUTES LES VERIFICATIONS PASSENT !"
    echo -e "======================================${NC}"
    exit 0
fi
